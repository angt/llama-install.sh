list(APPEND CMAKE_TRY_COMPILE_PLATFORM_VARIABLES LLAMA_INSTALL_OS LLAMA_INSTALL_ARCH)

if(LLAMA_INSTALL_OS STREQUAL "linux")
    set(CMAKE_SYSTEM_NAME "Linux")
elseif(LLAMA_INSTALL_OS STREQUAL "windows")
    set(CMAKE_SYSTEM_NAME "Windows")
elseif(LLAMA_INSTALL_OS STREQUAL "macos")
    set(CMAKE_SYSTEM_NAME "Darwin")
elseif(LLAMA_INSTALL_OS STREQUAL "freebsd")
    set(CMAKE_SYSTEM_NAME "FreeBSD")
elseif(LLAMA_INSTALL_OS STREQUAL "netbsd")
    set(CMAKE_SYSTEM_NAME "NetBSD")
elseif(LLAMA_INSTALL_OS STREQUAL "openbsd")
    set(CMAKE_SYSTEM_NAME "OpenBSD")
else()
    message(FATAL_ERROR "Unknown OS: ${LLAMA_INSTALL_OS}")
endif()

set(CMAKE_SYSTEM_PROCESSOR "${LLAMA_INSTALL_ARCH}")

if(DEFINED ENV{EXTRA_SYSROOT})
    set(CMAKE_FIND_ROOT_PATH "$ENV{EXTRA_SYSROOT}")
endif()

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
